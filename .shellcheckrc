# Shellcheck configuration for the dotfiles repo.
#
# We disable two warnings globally because they're false positives at scale
# in a shell library:
#
# SC1090 — "ShellCheck can't follow non-constant source." Most of our `source`
#          calls use $DOTFILES_DIR or runtime paths that shellcheck can't
#          resolve statically. The real targets exist (verified by bin/verify
#          and CI). Per-file `# shellcheck source=...` directives are added
#          where the path *is* statically knowable and we want to keep the
#          benefit of cross-file checking.
#
# SC2034 — "Variable appears unused." Library files (lib/runtime.sh,
#          lib/config.sh, lib/registry.sh, themes/*/colors.sh) are sourced
#          by other scripts that do consume these variables. Marking each
#          one with a per-line directive would be noisier than disabling.

disable=SC1090
disable=SC2034
external-sources=true
