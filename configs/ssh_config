# Per-machine SSH config (untracked): work Host blocks, IdentityFile, agent
# overrides, etc. Listed first so its values win (ssh takes the first value seen
# for each keyword). A missing file is silently ignored, so this is a no-op on
# machines that don't have one. See docs/customization.md.
Include ~/.ssh/config.local

Host *
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%C
    ControlPersist 600
    ServerAliveInterval 60
    ServerAliveCountMax 3
    AddKeysToAgent yes
    ForwardAgent no
    HashKnownHosts yes
    Compression yes


# Personal github account
Host github.com-tafk7
    HostName github.com
    User git
    IdentityFile ~/.ssh/id_ed25519_tafk7
    IdentitiesOnly yes
