#!/bin/bash
# Uninstall tools installed by the dotfiles system.
# Usage: uninstall-tool <name>    Remove a tool
#        uninstall-tool --list    Show installed tools

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="${DOTFILES_DIR:-$(dirname "$SCRIPT_DIR")}"

source "$DOTFILES_DIR/lib/runtime.sh"
source "$DOTFILES_DIR/lib/registry.sh"

show_usage() {
    echo "Usage: uninstall-tool <name>"
    echo "       uninstall-tool --list"
    echo ""
    echo "Remove tools installed by the dotfiles system."
}

list_tools() {
    echo "Tool              Status        Method    Location"
    echo "────────────────  ────────────  ────────  ────────────────────────────────"

    local names
    readarray -t names < <(printf '%s\n' "${!TOOL_BINARY[@]}" | sort)

    for name in "${names[@]}"; do
        local verify_cmd
        verify_cmd="$(tool_verify_command "$name")"
        local method="${TOOL_METHOD[$name]}"
        local paths
        paths="$(tool_uninstall_paths "$name")"

        local status="not found"
        local display_path=""

        if eval "$verify_cmd"; then
            status="installed"
            if [[ -n "$paths" ]]; then
                # Show first path, abbreviated
                local first_path="${paths%% *}"
                display_path="${first_path/#$HOME/~}"
            elif [[ "$method" == "apt" ]]; then
                display_path="(apt package)"
            fi
        fi

        printf "%-18s%-14s%-10s%s\n" "$name" "$status" "$method" "$display_path"
    done
}

uninstall_tool() {
    local name="$1"

    if [[ -z "${TOOL_BINARY[$name]+x}" ]]; then
        error "Unknown tool: $name"
        echo ""
        echo "Known tools:"
        printf '  %s\n' "$(printf '%s\n' "${!TOOL_BINARY[@]}" | sort)"
        exit 1
    fi

    local method="${TOOL_METHOD[$name]}"

    # Tools with removal instructions need manual steps
    if [[ -n "${TOOL_REMOVAL_INSTRUCTIONS[$name]:-}" ]]; then
        warn "$name requires manual removal:"
        echo "  ${TOOL_REMOVAL_INSTRUCTIONS[$name]}"
        exit 0
    fi

    case "$method" in
        apt)
            local binary="${TOOL_BINARY[$name]}"
            # Map binary name back to apt package name
            local apt_pkg="$name"
            case "$name" in
                bat) apt_pkg="bat" ;;
                fd)  apt_pkg="fd-find" ;;
                ripgrep) apt_pkg="ripgrep" ;;
                direnv) apt_pkg="direnv" ;;
            esac
            log "Removing apt package: $apt_pkg"
            sudo apt-get remove -y "$apt_pkg"
            success "$name uninstalled via apt"
            ;;
        eget|installer)
            local paths
            paths="$(tool_uninstall_paths "$name")"
            if [[ -z "$paths" ]]; then
                warn "No removal paths known for $name"
                exit 1
            fi

            local removed=false
            for path in $paths; do
                if [[ -e "$path" ]]; then
                    rm -rf "$path"
                    log "Removed: $path"
                    removed=true
                fi
            done

            if [[ "$removed" == true ]]; then
                success "$name uninstalled"
            else
                warn "$name was not installed (nothing to remove)"
            fi
            ;;
        *)
            error "Unknown install method: $method for $name"
            exit 1
            ;;
    esac
}

# Main
if [[ $# -eq 0 ]]; then
    show_usage
    exit 1
fi

case "$1" in
    --list|-l)
        list_tools
        ;;
    --help|-h)
        show_usage
        ;;
    *)
        uninstall_tool "$1"
        ;;
esac
