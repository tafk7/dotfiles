#!/bin/bash
# Dotfiles verification — checks configs, tools, and environment health.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="${DOTFILES_DIR:-$(dirname "$SCRIPT_DIR")}"

source "$DOTFILES_DIR/lib/runtime.sh"
source "$DOTFILES_DIR/lib/config.sh"
source "$DOTFILES_DIR/lib/theme-resolve.sh"

# Make sure on-disk theme overrides are reflected in this process's env so
# the cascade resolution below matches what apply_theme would do.
load_theme_overrides

# Counters
PASS=0
WARN=0
FAIL=0

check_pass() { echo -e "  ${GREEN}✅${NC} $1"; ((PASS++)) || true; }
check_warn() { echo -e "  ${YELLOW}⚠️${NC}  $1"; ((WARN++)) || true; }
check_fail() { echo -e "  ${RED}❌${NC} $1"; ((FAIL++)) || true; }

# ==============================================================================
# 1. CONFIG_MAP — check every symlink and template
# ==============================================================================

echo "Configuration files"
echo "─────────────────────────────────────"

readarray -t sorted_configs < <(printf '%s\n' "${!CONFIG_MAP[@]}" | sort)
for config in "${sorted_configs[@]}"; do
    local_mapping="${CONFIG_MAP[$config]}"
    target="${local_mapping%%:*}"
    type="${local_mapping##*:}"
    source_path="$(config_source_path "$config")"

    case "$type" in
        symlink)
            if [[ -L "$target" ]]; then
                link_dest="$(readlink -f "$target" 2>/dev/null || true)"
                real_source="$(readlink -f "$source_path" 2>/dev/null || true)"
                if [[ "$link_dest" == "$real_source" ]]; then
                    check_pass "$target → $config"
                else
                    check_warn "$target (symlink exists but points elsewhere)"
                fi
            elif [[ -e "$target" ]]; then
                check_warn "$target (exists but not a symlink)"
            else
                check_fail "$target (missing)"
            fi
            ;;
        gitconfig)
            if [[ -f "$target" ]]; then
                if grep -q '{{GIT_' "$target" 2>/dev/null; then
                    check_fail "$target (has unresolved template placeholders)"
                else
                    check_pass "$target (processed template)"
                fi
            else
                check_fail "$target (missing)"
            fi
            ;;
    esac
done

# ==============================================================================
# 2. Managed tools — single loop over registry, grouped by tier
# ==============================================================================

for tier in shell dev work ai; do
    readarray -t tier_tools < <(tools_for_tier "$tier")
    [[ ${#tier_tools[@]} -eq 0 ]] && continue

    echo
    echo "Tools [$tier tier]"
    echo "─────────────────────────────────────"

    for name in "${tier_tools[@]}"; do
        verify_cmd="$(tool_verify_command "$name")"
        binary="${TOOL_BINARY[$name]}"
        label="$name"
        [[ "$name" != "$binary" ]] && label="$name ($binary)"

        if eval "$verify_cmd"; then
            check_pass "$label"
        else
            # Optional tools — warn, not fail:
            #   - work tier (nvm/docker/azure) is opt-in
            #   - ai tier (claude/codex) is opt-in and may be org-managed
            #   - installer-based tools above the shell tier
            if [[ "$tier" == "work" || "$tier" == "ai" ]] \
               || [[ "${TOOL_METHOD[$name]}" == "installer" && "$tier" != "shell" ]]; then
                check_warn "$label (not installed)"
            else
                check_fail "$label (not found)"
            fi
        fi
    done
done

# ==============================================================================
# 3. Git configuration
# ==============================================================================

echo
echo "Git"
echo "─────────────────────────────────────"

git_name=$(git config --get user.name 2>/dev/null || true)
git_email=$(git config --get user.email 2>/dev/null || true)
if [[ -n "$git_name" && -n "$git_email" ]]; then
    check_pass "user: $git_name <$git_email>"
else
    check_warn "user not configured"
fi

# Pre-commit hook (info-level — never fail verify if absent).
hook_path="$DOTFILES_DIR/.git/hooks/pre-commit"
if [[ -L "$hook_path" ]]; then
    resolved="$(readlink -f "$hook_path" 2>/dev/null || true)"
    if [[ "$resolved" == "$DOTFILES_DIR/hooks/"* ]]; then
        check_pass "pre-commit hook installed (symlink → hooks/pre-commit)"
    else
        check_warn "pre-commit hook present but not from this repo"
    fi
elif [[ -f "$hook_path" ]] && head -n4 "$hook_path" 2>/dev/null | grep -q "Installed by bin/install-git-hooks"; then
    check_pass "pre-commit hook installed (copy)"
elif [[ -f "$hook_path" ]]; then
    check_warn "pre-commit hook present but not from this repo"
else
    check_warn "pre-commit hook not installed (run: bin/install-git-hooks)"
fi

# ==============================================================================
# 4. Docker
# ==============================================================================

if command -v docker >/dev/null 2>&1; then
    echo
    echo "Docker"
    echo "─────────────────────────────────────"

    if grep "^docker:" /etc/group 2>/dev/null | grep -q "\b$USER\b"; then
        if groups | grep -q docker; then
            check_pass "docker group (active)"
        else
            check_warn "docker group (added — restart shell to activate)"
        fi
    else
        check_fail "not in docker group (sudo usermod -aG docker $USER)"
    fi
fi

# ==============================================================================
# 5. WSL
# ==============================================================================

if is_wsl; then
    echo
    echo "WSL"
    echo "─────────────────────────────────────"

    if [[ -x "$HOME/.local/bin/pbcopy" ]]; then
        check_pass "clipboard integration"
    else
        check_warn "clipboard scripts not installed (run setup.sh)"
    fi
fi

# ==============================================================================
# 6. Environment files
# ==============================================================================

echo
echo "Environment"
echo "─────────────────────────────────────"

if [[ -f "$DOTFILES_DIR/generated/bridge.sh" ]]; then
    check_pass "generated/bridge.sh"
else
    check_warn "bridge file missing (run setup.sh)"
fi

if [[ -f "$DOTFILES_DIR/generated/theme.sh" ]]; then
    # Extract theme name from generated/theme.sh
    theme=$(grep -oP 'DOTFILES_THEME="\K[^"]+' "$DOTFILES_DIR/generated/theme.sh" 2>/dev/null || true)
    if [[ -n "$theme" ]]; then
        check_pass "theme: $theme"
    else
        check_warn "theme.sh exists but no theme name found"
    fi
else
    check_warn "no theme set (run: bin/theme-switcher <theme>)"
    theme=""
fi

# ==============================================================================
# 6b. Theme integration — per-surface wiring (cascade-aware)
# ==============================================================================

if [[ -n "$theme" ]]; then
    # Resolve effective theme per surface using the loaded overrides.
    # `theme` here is the global default; overrides may select something else.
    DOTFILES_THEME="$theme"
    r_bat="$(resolve_surface_theme bat)"
    r_starship="$(resolve_surface_theme starship)"
    r_delta="$(resolve_surface_theme delta)"
    r_btop="$(resolve_surface_theme btop)"
    r_lazygit="$(resolve_surface_theme lazygit)"

    # Heading: collapsed when no overrides, expanded otherwise.
    overrides_active=0
    for g in code chrome apps; do
        group_has_override "$g" && overrides_active=1
    done
    for s in vim bat delta tmux starship fzf btop lazygit; do
        surface_has_override "$s" && overrides_active=1
    done

    echo
    if [[ $overrides_active -eq 0 ]]; then
        echo "Theme integration [$theme]"
    else
        echo "Theme integration [global=$theme — per-component overrides active]"
    fi
    echo "─────────────────────────────────────"

    # bat: built-in themes (gruvbox-dark, Nord) need no vendored file
    if [[ -d "$DOTFILES_DIR/themes/$r_bat/bat" ]]; then
        bat_files=("$DOTFILES_DIR/themes/$r_bat/bat"/*.tmTheme)
        if [[ -e "${bat_files[0]}" ]]; then
            check_pass "bat [$r_bat]: vendored ${#bat_files[@]} .tmTheme file(s)"
            if [[ -f "$DOTFILES_DIR/generated/bat/cache/themes.bin" ]]; then
                check_pass "bat: isolated cache built (generated/bat/cache/themes.bin)"
            else
                check_warn "bat: isolated cache missing (run bin/theme-switcher $r_bat)"
            fi
        else
            check_warn "bat [$r_bat]: themes/$r_bat/bat exists but is empty"
        fi
    else
        check_pass "bat [$r_bat]: uses bat built-in (no vendored .tmTheme needed)"
    fi

    # starship: generated/starship.toml + palette directive
    if [[ -f "$DOTFILES_DIR/generated/starship.toml" ]]; then
        if grep -q "^palette = \"$r_starship\"" "$DOTFILES_DIR/generated/starship.toml"; then
            check_pass "starship [$r_starship]: generated/starship.toml pinned correctly"
        else
            check_warn "starship: generated config palette doesn't match resolved theme '$r_starship'"
        fi
    else
        check_warn "starship: generated/starship.toml missing (run bin/theme-switcher --init)"
    fi

    # delta: generated/delta.gitconfig + ~/.gitconfig include
    if [[ -f "$DOTFILES_DIR/generated/delta.gitconfig" ]]; then
        if grep -q "features = $r_delta" "$DOTFILES_DIR/generated/delta.gitconfig"; then
            check_pass "delta [$r_delta]: generated/delta.gitconfig active"
        else
            check_warn "delta: generated config doesn't list resolved theme '$r_delta'"
        fi
        if git config --global --get-all include.path 2>/dev/null | grep -Fxq "$DOTFILES_DIR/generated/delta.gitconfig"; then
            check_pass "delta: ~/.gitconfig includes generated/delta.gitconfig"
        else
            check_warn "delta: ~/.gitconfig missing include for generated/delta.gitconfig"
        fi
    else
        if [[ -f "$DOTFILES_DIR/themes/$r_delta/delta.gitconfig" ]]; then
            check_warn "delta: generated/delta.gitconfig missing"
        fi
    fi

    # btop: ~/.config/btop/btop.conf color_theme
    if [[ -f "$HOME/.config/btop/btop.conf" ]]; then
        if grep -qE "^color_theme = \"dotfiles-$r_btop\"" "$HOME/.config/btop/btop.conf"; then
            check_pass "btop [$r_btop]: color_theme set to dotfiles-$r_btop"
        else
            current_btop=$(grep -oE '^color_theme = "[^"]+"' "$HOME/.config/btop/btop.conf" | head -1 || true)
            check_warn "btop: color_theme not pinned to dotfiles-$r_btop ($current_btop)"
        fi
    else
        if [[ -f "$DOTFILES_DIR/themes/$r_btop/btop.theme" ]]; then
            check_warn "btop: ~/.config/btop/btop.conf missing (run bin/theme-switcher $r_btop)"
        fi
    fi

    # lazygit: marker block in ~/.config/lazygit/config.yml
    if [[ -f "$HOME/.config/lazygit/config.yml" ]]; then
        if grep -qF "# >>> dotfiles theme >>>" "$HOME/.config/lazygit/config.yml"; then
            check_pass "lazygit [$r_lazygit]: dotfiles theme block present"
        else
            check_warn "lazygit: config.yml missing dotfiles theme marker"
        fi
    else
        if [[ -f "$DOTFILES_DIR/themes/$r_lazygit/lazygit.yml" ]]; then
            check_warn "lazygit: ~/.config/lazygit/config.yml missing"
        fi
    fi

    # Override summary (only when active)
    if [[ $overrides_active -eq 1 ]]; then
        echo
        ovs="$(_theme_overrides_list || true)"
        if [[ -n "$ovs" ]]; then
            log "Active overrides:"
            printf '%s\n' "$ovs" | sed 's/^/    /'
            log "Run 'theme-switcher show' for the full cascade tree."
        fi
    fi
fi

# ==============================================================================
# 7. EDITOR conflict detection
# ==============================================================================

echo
echo "Conflict checks"
echo "─────────────────────────────────────"

editor_conflict=false
for alias_file in "$DOTFILES_DIR"/shell/tools/*.sh; do
    if [[ -f "$alias_file" ]] && grep -v "^[[:space:]]*#" "$alias_file" 2>/dev/null | grep -q "^[[:space:]]*export EDITOR"; then
        check_warn "EDITOR set in $(basename "$alias_file") (should only be in shell/env.sh)"
        editor_conflict=true
    fi
done
if [[ "$editor_conflict" == false ]]; then
    check_pass "EDITOR (single source: shell/env.sh)"
fi

# ==============================================================================
# Summary
# ==============================================================================

echo
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo -e "  ${GREEN}✅ $PASS passed${NC}  ${YELLOW}⚠️  $WARN warnings${NC}  ${RED}❌ $FAIL errors${NC}"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

exit "$FAIL"
