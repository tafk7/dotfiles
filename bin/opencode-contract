#!/bin/bash
# opencode-contract — snapshot and drift-check opencode's machine-readable contract.
#
# Why this exists: opencode self-updates silently and ships patch releases
# constantly, with no versioned docs and no llms.txt. The pinnable sources of
# truth are:
#   1. the installed binary's --help / --version (exact for the running version)
#   2. the config JSON schema at opencode.ai/config.json + tui.json ("latest")
#   3. the CLI command source in the repo, pinnable by release tag
#      (repo moved sst/opencode -> anomalyco/opencode)
# This tool captures those into a committed baseline, then diffs a fresh capture
# against it — so a contract change surfaces as a reviewable git diff instead of
# a silent surprise the next time we write opencode integration code.
#
# Usage:
#   bin/opencode-contract capture      # (re)write the baseline; commit the result
#   bin/opencode-contract check        # diff live contract vs baseline; exit 1 on drift
#   bin/opencode-contract show         # print the stored baseline manifest
#   bin/opencode-contract docs [dir]   # mirror the full docs tree locally for reading
#                                      # (default: generated/opencode-docs, gitignored)
#   bin/opencode-contract egress       # list outbound hosts referenced in the source
#
# Needs network (opencode.ai, api.github.com, raw.githubusercontent.com). The
# runtime section also needs opencode on PATH; it is skipped (with a warning) if
# absent, and unreachable sources warn rather than abort. Export GITHUB_TOKEN to
# avoid GitHub's 60 req/hr anonymous rate limit (HTTP 403).
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DOTFILES_DIR="${DOTFILES_DIR:-$(dirname "$SCRIPT_DIR")}"
source "$DOTFILES_DIR/lib/runtime.sh"

# Repo is anomalyco/opencode since the SST->Anomaly rename (sst/opencode still
# redirects for now). config.json/tui.json live on the opencode.ai domain.
REPO="anomalyco/opencode"
SCHEMA_URLS=(https://opencode.ai/config.json https://opencode.ai/tui.json)
# Pinnable CLI/config source (relative to packages/opencode/src). Files absent at
# a given tag just warn — the diff stays consistent as long as capture and check
# resolve the same set.
SRC_FILES=(
    index.ts
    cli/cmd/run.ts cli/cmd/serve.ts cli/cmd/upgrade.ts cli/upgrade.ts
    cli/cmd/agent.ts cli/cmd/auth.ts cli/cmd/mcp.ts cli/cmd/models.ts
    cli/cmd/stats.ts cli/cmd/github.ts cli/cmd/acp.ts
)
# The prose docs are Astro Starlight markdown in the repo. The rendered
# opencode.ai/docs site blocks automated fetchers, but the .mdx source doesn't —
# so the docs ARE reachable/pinnable here. cli.mdx + config.mdx carry the
# flag/config surface, so they belong in the drift snapshot; `docs` (below)
# mirrors the full tree for reading.
DOCS_SRC_DIR="packages/web/src/content/docs"
DOC_FILES=(cli.mdx config.mdx)
# Root of the CLI source tree — `egress` scans all *.ts under here when a token
# lets it enumerate via the tree API.
SRC_TREE_DIR="packages/opencode/src"
# (The runtime REST API contract — OpenAPI 3.1 for `opencode serve` — lives at
# raw .../packages/sdk/openapi.json. It's ~1 MB and churns a lot, and we don't
# use the server API, so it's intentionally NOT in the drift baseline. Fetch it
# directly if you ever need it — see docs/opencode-contract.md.)
# Overridable for testing; the committed baseline lives under docs/.
BASELINE_DIR="${OPENCODE_CONTRACT_DIR:-$DOTFILES_DIR/docs/opencode-contract}"

# Temp dir for `check`. Script-global (not a function local) so the EXIT trap can
# clean it up without tripping `set -u` after the function returns.
_OC_TMP=""
cleanup() { [[ -n "${_OC_TMP:-}" ]] && rm -rf "$_OC_TMP"; }
trap cleanup EXIT

# Resolve the latest release tag; fall back to the dev branch on any failure
# (rate limit, network, lagging /releases/latest pointer).
resolve_tag() {
    local -a hdr=()
    [[ -n "${GITHUB_TOKEN:-}" ]] && hdr=(-H "Authorization: Bearer $GITHUB_TOKEN")
    local tag
    tag="$(curl -fsS --max-time 20 "${hdr[@]}" \
        "https://api.github.com/repos/$REPO/releases/latest" 2>/dev/null \
        | grep -o '"tag_name"[[:space:]]*:[[:space:]]*"[^"]*"' | head -1 \
        | cut -d'"' -f4 || true)"
    printf '%s' "${tag:-dev}"
}

# Fetch every contract artifact into $1, pinning source to tag $2.
fetch_into() {
    local dest="$1" tag="$2"
    mkdir -p "$dest"

    local url name
    for url in "${SCHEMA_URLS[@]}"; do
        name="schema.$(basename "$url")"
        curl -fsSL --max-time 30 "$url" -o "$dest/$name" \
            || warn "could not fetch $url (schema)"
    done

    local base="https://raw.githubusercontent.com/$REPO/$tag/packages/opencode/src"
    local f out
    for f in "${SRC_FILES[@]}"; do
        out="src.${f//\//.}"
        curl -fsSL --max-time 30 "$base/$f" -o "$dest/$out" \
            || warn "could not fetch src $f @ $tag"
    done

    local d
    for d in "${DOC_FILES[@]}"; do
        curl -fsSL --max-time 30 "https://raw.githubusercontent.com/$REPO/$tag/$DOCS_SRC_DIR/$d" \
            -o "$dest/doc.$d" || warn "could not fetch doc $d @ $tag"
    done

    if command -v opencode >/dev/null 2>&1; then
        opencode --version    > "$dest/runtime.version.txt"  2>/dev/null || true
        opencode --help       > "$dest/runtime.help.txt"     2>&1        || true
        opencode run --help   > "$dest/runtime.run.help.txt" 2>&1        || true
    else
        warn "opencode not on PATH — skipping runtime --help capture"
    fi
}

write_manifest() {
    local dest="$1" tag="$2"
    {
        echo "repo: $REPO"
        echo "release_tag: $tag"
        echo "captured_utc: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
        if command -v opencode >/dev/null 2>&1; then
            echo "opencode_version: $(opencode --version 2>/dev/null | head -1)"
        else
            echo "opencode_version: (not installed at capture)"
        fi
    } > "$dest/MANIFEST"
}

cmd_capture() {
    local tag; tag="$(resolve_tag)"
    log "Capturing opencode contract (repo $REPO, tag $tag)..."
    rm -rf "$BASELINE_DIR"
    fetch_into "$BASELINE_DIR" "$tag"
    write_manifest "$BASELINE_DIR" "$tag"
    success "Baseline written to ${BASELINE_DIR#"$DOTFILES_DIR"/} — review and commit it."
}

cmd_check() {
    [[ -d "$BASELINE_DIR" ]] || {
        error "No baseline found at $BASELINE_DIR"
        error "Create one first: bin/opencode-contract capture"
        exit 1
    }
    local tag; tag="$(resolve_tag)"
    log "Checking live opencode contract (tag $tag) against baseline..."

    _OC_TMP="$(mktemp -d)"
    fetch_into "$_OC_TMP" "$tag"

    # MANIFEST carries the tag/date/version and always differs — exclude it; the
    # content artifacts are the contract.
    local report
    if report="$(diff -rq -x MANIFEST "$BASELINE_DIR" "$_OC_TMP" 2>&1)"; then
        success "opencode contract UNCHANGED vs baseline (tag $tag)"
    else
        warn "DRIFT DETECTED — the opencode contract moved:"
        printf '%s\n' "$report" | sed 's/^/  /'
        echo
        echo "Inspect the diffs, update any affected installer/wrapper/aliases,"
        echo "then re-baseline: bin/opencode-contract capture"
        exit 1
    fi
}

# Enumerate every docs .md/.mdx path via the GitHub tree API (needs a token to
# dodge the 60 req/hr anonymous limit). Empty output => couldn't enumerate.
list_doc_paths() {
    local tag="$1"
    local -a hdr=()
    [[ -n "${GITHUB_TOKEN:-}" ]] && hdr=(-H "Authorization: Bearer $GITHUB_TOKEN")
    curl -fsS --max-time 30 "${hdr[@]}" \
        "https://api.github.com/repos/$REPO/git/trees/$tag?recursive=1" 2>/dev/null \
        | grep -oE "\"path\"[[:space:]]*:[[:space:]]*\"$DOCS_SRC_DIR/[^\"]*\.mdx?\"" \
        | cut -d'"' -f4
}

# Mirror the full docs tree locally for reading/grepping (into gitignored
# generated/ by default). This is the "docs as an endpoint" — the source the
# rendered site is built from, pinned to a release tag.
cmd_docs() {
    local outdir="${1:-$DOTFILES_DIR/generated/opencode-docs}"
    local tag; tag="$(resolve_tag)"
    log "Mirroring opencode docs ($DOCS_SRC_DIR @ $tag) -> $outdir"

    local -a paths=()
    readarray -t paths < <(list_doc_paths "$tag")
    if [[ ${#paths[@]} -eq 0 ]]; then
        error "Could not enumerate docs via the GitHub tree API (rate limit? set GITHUB_TOKEN)."
        error "Single page on demand: curl -fsSL https://raw.githubusercontent.com/$REPO/$tag/$DOCS_SRC_DIR/<page>.mdx"
        exit 1
    fi

    rm -rf "$outdir"; mkdir -p "$outdir"
    local p rel n=0
    for p in "${paths[@]}"; do
        rel="${p#"$DOCS_SRC_DIR"/}"
        mkdir -p "$outdir/$(dirname "$rel")"
        if curl -fsSL --max-time 30 "https://raw.githubusercontent.com/$REPO/$tag/$p" -o "$outdir/$rel"; then
            n=$((n + 1))
        else
            warn "fetch failed: $p"
        fi
    done
    success "Mirrored $n/${#paths[@]} doc files to ${outdir#"$DOTFILES_DIR"/} (tag $tag)."
}

cmd_show() {
    if [[ -f "$BASELINE_DIR/MANIFEST" ]]; then
        cat "$BASELINE_DIR/MANIFEST"
    else
        error "No baseline manifest at $BASELINE_DIR — run: bin/opencode-contract capture"
        exit 1
    fi
}

# Enumerate every *.ts under the CLI source tree (needs a token for the tree API).
list_source_paths() {
    local tag="$1"
    local -a hdr=()
    [[ -n "${GITHUB_TOKEN:-}" ]] && hdr=(-H "Authorization: Bearer $GITHUB_TOKEN")
    curl -fsS --max-time 30 "${hdr[@]}" \
        "https://api.github.com/repos/$REPO/git/trees/$tag?recursive=1" 2>/dev/null \
        | grep -oE "\"path\"[[:space:]]*:[[:space:]]*\"$SRC_TREE_DIR/[^\"]*\.ts\"" \
        | cut -d'"' -f4
}

# List the external hosts referenced in the source — the egress surface. NOT a
# runtime capture: enforce no-egress at the network layer and verify with
# tcpdump. Value here is (a) a full-tree scan when a token is available, and
# (b) drift — a self-update that introduces a NEW outbound host shows up so you
# can decide whether to allowlist or block it.
cmd_egress() {
    local tag; tag="$(resolve_tag)"
    _OC_TMP="$(mktemp -d)"

    local scope
    local -a paths=()
    readarray -t paths < <(list_source_paths "$tag")
    if [[ ${#paths[@]} -gt 0 ]]; then
        log "Scanning all ${#paths[@]} source files under $SRC_TREE_DIR (tag $tag)..."
        local p n=0
        for p in "${paths[@]}"; do
            if curl -fsSL --max-time 20 "https://raw.githubusercontent.com/$REPO/$tag/$p" \
                -o "$_OC_TMP/${p//\//.}" 2>/dev/null; then n=$((n + 1)); fi
        done
        scope="full source tree ($n/${#paths[@]} files, tag $tag)"
    else
        warn "Full source enumeration unavailable (GitHub tree API rate-limited)."
        warn "Set GITHUB_TOKEN for a complete scan. Falling back to the ${#SRC_FILES[@]} tracked CLI files."
        fetch_into "$_OC_TMP" "$tag"
        scope="tracked CLI files only — PARTIAL (set GITHUB_TOKEN for a full scan)"
    fi

    echo
    echo "Outbound hosts referenced in the $scope:"
    # Only *.ts (source) — doc .mdx files are full of example URLs that are noise.
    grep -rhoE 'https?://[A-Za-z0-9._-]+' "$_OC_TMP" --include='*.ts' 2>/dev/null \
        | sed -E 's#^https?://##' \
        | grep -viE '^(localhost|127\.0\.0\.1|0\.0\.0\.0|example\.(com|org|net))$' \
        | sort -u | sed 's/^/  /'
    echo
    echo "Not a runtime capture. For a hard no-egress guarantee, allowlist at the"
    echo "network layer and verify with tcpdump — see docs/opencode-secure.md."
}

main() {
    case "${1:-}" in
        capture) cmd_capture ;;
        check)   cmd_check ;;
        show)    cmd_show ;;
        docs)    cmd_docs "${2:-}" ;;
        egress)  cmd_egress ;;
        ""|-h|--help)
            sed -n '2,25p' "${BASH_SOURCE[0]}" | sed 's/^# \{0,1\}//'
            ;;
        *)
            error "Unknown command: $1"
            echo "Usage: opencode-contract [capture|check|show|docs [outdir]|egress]" >&2
            exit 1
            ;;
    esac
}

main "$@"
