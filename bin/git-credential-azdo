#!/bin/sh
# Git credential helper for Azure DevOps.
# Uses `az` CLI to obtain an OAuth token — requires `az login`.
#
# Install:
#   git config --global 'credential.https://msasg.visualstudio.com.helper' azdo

if [ "$1" != "get" ]; then
    exit 0
fi

token=$(az account get-access-token \
    --resource 499b84ac-1321-427f-aa17-267ca6975798 \
    --query accessToken -o tsv 2>/dev/null)

if [ -z "$token" ]; then
    exit 1
fi

printf 'username=azdo\npassword=%s\n' "$token"
